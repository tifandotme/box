#!/usr/bin/env bash

set -Eeuo pipefail

host="eddies@box.javanese-pound.ts.net"
storage_path="/home/eddies/hermes-storage"
storage_owner="1001:1001"

# Values are intentionally quoted locally before being passed to SSH.
# shellcheck disable=SC2029
ssh "$host" "STORAGE_PATH=$(printf '%q' "$storage_path") STORAGE_OWNER=$(printf '%q' "$storage_owner") bash -s" <<'REMOTE'
set -Eeuo pipefail

sudo mkdir -p "$STORAGE_PATH"
sudo chown -R "$STORAGE_OWNER" "$STORAGE_PATH"
sudo chmod u+rwX "$STORAGE_PATH"
REMOTE
